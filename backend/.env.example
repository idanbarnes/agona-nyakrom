# ─────────────────────────────────────────
# Server Configuration (Example)
# ─────────────────────────────────────────
PORT=5000
NODE_ENV=development
TRUST_PROXY=false
DATABASE_URL=

# ─────────────────────────────────────────
# PostgreSQL Database Configuration (Example)
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD_HERE
DB_NAME=your_database_name
DB_SSL=false

# ─────────────────────────────────────────
# Security Settings (Example)
# ─────────────────────────────────────────
JWT_SECRET=YOUR_SECRET_KEY_HERE
PREVIEW_TOKEN_SECRET=YOUR_PREVIEW_SECRET_KEY_HERE
JWT_EXPIRES_IN=1d
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
ADMIN_BOOTSTRAP_TOKEN=CHANGE_ME_FOR_FIRST_ADMIN_SETUP
ALLOW_ADMIN_BOOTSTRAP_WHEN_ADMINS_EXIST=false
ADMIN_PASSWORD_MIN_LENGTH=10

# Public frontend origin for admin preview URLs
PUBLIC_SITE_URL=http://localhost:5174
ADMIN_SITE_URL=http://localhost:5173
PUBLIC_ASSET_BASE_URL=http://localhost:5000
PUBLIC_SHARE_IMAGE_URL=http://localhost:5174/share-default.svg

# ─────────────────────────────────────────
# File Upload Settings (Example)
# ─────────────────────────────────────────
MEDIA_STORAGE=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_BASE_FOLDER=agonanyakrom
